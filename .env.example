# 数据库类型: postgresql 或 sqlite
DB_TYPE=sqlite

# PostgreSQL 配置 (仅当 DB_TYPE=postgresql 时需要)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=aps_dev

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 服务配置
HOST=0.0.0.0
PORT=8000

# GitHub 仓库配置 (用于检查更新)
# 格式: owner/repo，例如: username/python-visual-task-scheduler
GITHUB_REPO=

# API 安全配置
# 是否启用 API Key 认证
API_KEY_ENABLED=true
# API 密钥 (建议使用随机字符串，如: openssl rand -hex 32)
API_KEY=